<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cabeleleila Leila: Cadastre-se</title>
    <link rel="stylesheet" href="assets/css/logCad.css">
</head>
<body>
    <div class="wrapper">
        <h1>Cadastro</h1>
        <p id="mensagemErro"></p>
        <form id="form" method="post">

            <div>
                <label for="nomeInput">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="M367-527q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47ZM160-160v-112q0-34 17.5-62.5T224-378q62-31 126-46.5T480-440q66 0 130 15.5T736-378q29 15 46.5 43.5T800-272v112H160Z"/></svg>
                </label>
                <input type="text" name="nome" id="nomeInput" placeholder="Seu Nome">
            </div>

            <div>
                <label for="emailInput">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480v58q0 59-40.5 100.5T740-280q-35 0-66-15t-52-43q-29 29-65.5 43.5T480-280q-83 0-141.5-58.5T280-480q0-83 58.5-141.5T480-680q83 0 141.5 58.5T680-480v58q0 26 17 44t43 18q26 0 43-18t17-44v-58q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93h200v80H480Zm85-315q35-35 35-85t-35-85q-35-35-85-35t-85 35q-35 35-35 85t35 85q35 35 85 35t85-35Z"/></svg>
                </label>
                <input type="email" name="email" id="emailInput" placeholder="Seu Email">
            </div>

            <div>
                <label for="senhaInput">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="M365-395q35-35 35-85t-35-85q-35-35-85-35t-85 35q-35 35-35 85t35 85q35 35 85 35t85-35Zm-85 155q-100 0-170-70T40-480q0-100 70-170t170-70q81 0 141.5 46T506-560h335l79 79-140 160-100-79-80 80-80-80h-14q-25 72-87 116t-139 44Z"/></svg>
                </label>
                <input type="password" name="senha" id="senhaInput" placeholder="Sua Senha">
            </div>

            <div>
                <label for="confirmarSenhaInput">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="M365-395q35-35 35-85t-35-85q-35-35-85-35t-85 35q-35 35-35 85t35 85q35 35 85 35t85-35Zm-85 155q-100 0-170-70T40-480q0-100 70-170t170-70q81 0 141.5 46T506-560h335l79 79-140 160-100-79-80 80-80-80h-14q-25 72-87 116t-139 44Z"/></svg>
                </label>
                <input type="password" name="confirmarSenha" id="confirmarSenhaInput" placeholder="Confirme sua senha">
            </div>

            <button type="submit">
                Cadastre-se!
            </button>
        </form>
        <p>Ja é cliente? <a href="login">Entrar</a></p>
    </div>


    <script>
        const form = document.getElementById("form")
        const mensagemErro = document.getElementById("mensagemErro")
        const nomeInput = document.getElementById("nomeInput")
        const emailInput = document.getElementById("emailInput")
        const senhaInput = document.getElementById("senhaInput")
        const confirmarSenhaInput = document.getElementById("confirmarSenhaInput")

        form.addEventListener("submit", (e) => {
            // e.preventDefault()


            let erros = []


            erros = getErrosCadastro(nomeInput.value, emailInput.value, senhaInput.value, confirmarSenhaInput.value)


            console.log(erros)

            if(erros.length > 0){
                e.preventDefault()
                console.log("ERO")
                mensagemErro.innerText = erros.join("\n")
            }

        })

        function getErrosCadastro(nome, email, senha, senhaConfirmar){
            let erros = []

            if(nome === "" || nome == null){
                erros.push("Nome é um campo obrigatorio")
                nomeInput.parentElement.classList.add("errado")
            }

            if(email === "" || email == null){
                erros.push("email é um campo obrigatorio")
                emailInput.parentElement.classList.add("errado")
            } 
            if(email.indexOf("@") === -1){
                erros.push("email invalido")
                emailInput.parentElement.classList.add("errado")
            }

            if(senha === "" || senha == null){
                erros.push("Senha é um campo obrigatorio")
                senhaInput.parentElement.classList.add("errado")
            } else {
                if(!senhaMin(senha)){
                    erros.push("A senha deve conter: pelo menos 1 (digito, maiscula, minuscula e simbolo) e mais que 5 caracteres")
                    senhaInput.parentElement.classList.add("errado")

                }
            }

            if(senhaConfirmar != senha){
                erros.push("As senhas não coincidem.")
                senhaInput.parentElement.classList.add("errado")
                confirmarSenhaInput.parentElement.classList.add("errado")
            }

            return erros
            
        }

        function senhaMin(senha){
            // REGEX PARA A SENHA TER OBRIGATORIAMENTE UMA LETRA MAISCULA, MINUSCULA, SIMBOLO E NUMERO, E TER DE 6 A 32 DIGITOS
            const regX = /^(?=.*[0-9])(?=.*[a-z])(?=.*[A-Z])(?=.*[@#$%^&+=])(?=\S+$).{6,32}$/
            return regX.test(senha)
        }

        const inputs = [nomeInput, emailInput, senhaInput, confirmarSenhaInput]

        inputs.forEach(i => {
          i.addEventListener("input", () => {
            if(i.parentElement.classList.contains("errado")){
                mensagemErro.innerText = ""
                i.parentElement.classList.remove("errado")
            }
          })  
        })
    </script>
</body>
</html>